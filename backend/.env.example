# ─── SwarmCourt Backend Environment Variables ─────────────────
# Copy this to .env and fill in your values

# ─── AI Providers(for demo running the agents locally) ─────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── IPFS Storage (Pinata) ───────────────────────────────────
PINATA_JWT=

# ─── Solana ──────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9tMjJZB4DCJABpxYFJUi6VRSU1MZB2L5uf145f6AJytz
#this program id is of the main deployed swarmcourt contract

# Orchestrator wallet secret key (base58 encoded)
ORCHESTRATOR_SECRET_KEY=

# Admin wallet public key (receives 5% protocol fee)
ADMIN_WALLET_ADDRESS=

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:3000,ht
